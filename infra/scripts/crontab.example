# ===========================================
# VPS crontab for ImobIntel
# Install with: crontab scripts/crontab.example
# ===========================================

# Crawl tick — every 5 minutes
*/5 * * * * curl -sf --max-time 30 http://localhost:3000/api/cron/crawl-tick > /dev/null 2>&1

# Dedup tick — every 15 minutes
*/15 * * * * curl -sf --max-time 60 http://localhost:3000/api/cron/dedup-tick > /dev/null 2>&1

# Area aggregator — daily at 3 AM
0 3 * * * curl -sf --max-time 120 http://localhost:3000/api/cron/area-aggregator > /dev/null 2>&1

# Backup — daily at 4 AM
0 4 * * * cd /home/deploy/imob/infra && docker compose --profile backup run --rm backup >> /var/log/imob-backup.log 2>&1

# Healthcheck — every 10 minutes
*/10 * * * * cd /home/deploy/imob/infra && ./scripts/healthcheck.sh >> /var/log/imob-health.log 2>&1
