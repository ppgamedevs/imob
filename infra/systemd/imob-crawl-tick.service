[Unit]
Description=ImobIntel crawl-tick (process crawl queue batch)
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/bin/curl -sf -H "Authorization: Bearer ${CRON_SECRET}" http://localhost:3000/api/cron/crawl-tick
EnvironmentFile=/home/admin/apps/imob/infra/.env
TimeoutStartSec=90
