[Unit]
Description=ImobIntel crawl-refresh (revisit recent analyses for price updates)
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/bin/curl -sf -H "Authorization: Bearer ${CRON_SECRET}" http://localhost:3000/api/cron/crawl-refresh
EnvironmentFile=/home/admin/apps/imob/infra/.env
TimeoutStartSec=120
