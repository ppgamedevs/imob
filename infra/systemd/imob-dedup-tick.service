[Unit]
Description=ImobIntel dedup-tick (group duplicate listings)
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/bin/sh -c 'curl -sf -H "Authorization: Bearer $CRON_SECRET" "${CRON_BASE_URL:-https://imobintel.ro}/api/cron/dedup-tick"'
EnvironmentFile=/home/admin/apps/imob/infra/.env
TimeoutStartSec=90
