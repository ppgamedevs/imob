# ===========================================
# Infra — Environment Variables
# ===========================================
# Copy to .env and fill in real values before deploying.

# --- Postgres ---
POSTGRES_USER=imobintel
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=imobintel
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
PG_EXTERNAL_PORT=5432

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# --- Domain (used by Caddy for automatic TLS) ---
DOMAIN=db.imob.ro

# --- Backup ---
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7

# ===========================================
# Vercel DATABASE_URL (set this in Vercel env vars)
# ===========================================
# Format: postgresql://POSTGRES_USER:POSTGRES_PASSWORD@YOUR_VPS_IP:PG_EXTERNAL_PORT/POSTGRES_DB?sslmode=require
# Example: postgresql://imobintel:CHANGE_ME@65.108.xx.xx:5432/imobintel?sslmode=require
