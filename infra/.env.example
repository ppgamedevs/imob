# ===========================================
# Infra — Environment Variables (VPS)
# ===========================================
# Copy to .env and fill in real values before deploying.
# Generate passwords: openssl rand -base64 32

# ─── Postgres ────────────────────────────────────────────────
# Superuser (for migrations only — never used by the app at runtime)
POSTGRES_USER=imobintel_admin
POSTGRES_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
POSTGRES_DB=imobintel

# App user (least privilege — used by the Next.js API container)
IMOBINTEL_APP_USER=imobintel
IMOBINTEL_APP_PASSWORD=CHANGE_ME_APP_PASSWORD

# ─── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ─── Domains ─────────────────────────────────────────────────
# DNS setup:
#   imobintel.ro        → Vercel (frontend)
#   api.imobintel.ro    → VPS IP (Caddy → API container)
#   status.imobintel.ro → VPS IP (Caddy → Uptime Kuma) [optional]
API_DOMAIN=api.imobintel.ro
STATUS_DOMAIN=status.imobintel.ro
ACME_EMAIL=admin@imob.ro
CORS_ORIGIN=https://imobintel.ro

# ─── ImobIntel App ──────────────────────────────────────────
# DATABASE_URL uses the app user (least-privilege), not the admin.
# This is constructed automatically by docker-compose from the vars above.
# The container receives: postgresql://imobintel:password@postgres:5432/imobintel

# Auth: NEXTAUTH_URL must be the FRONTEND domain (where users see the browser URL).
# Even though auth routes are proxied from Vercel → VPS, cookies and OAuth
# callbacks use this URL. It must match the Vercel web domain.
NEXTAUTH_URL=https://imobintel.ro
NEXTAUTH_SECRET=CHANGE_ME_NEXTAUTH_SECRET

NEXT_PUBLIC_BASE_URL=https://imobintel.ro
NEXT_PUBLIC_SITE_URL=https://imobintel.ro

# Google OAuth: callback URL in Google Console must be:
#   https://imobintel.ro/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=

RESEND_API_KEY=
EMAIL_FROM=noreply@imobintel.ro

ADMIN_TOKEN=CHANGE_ME_ADMIN_TOKEN
AGENT_SESSION_SECRET=CHANGE_ME_AGENT_SECRET

# Cron secret — protects all /api/cron/* endpoints
CRON_SECRET=CHANGE_ME_CRON_SECRET

SENTRY_DSN=
LOG_LEVEL=info
ALLOW_SERVER_SCRAPE=true
SERVER_WHITELIST=imobiliare.ro,olx.ro,storia.ro

# ─── Backup ─────────────────────────────────────────────────
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7

# ─── Additional projects (optional) ─────────────────────────
# Uncomment and set passwords to create DBs on first boot.
#
# ROMARKETCAP_DB=romarketcap
# ROMARKETCAP_DB_USER=romarketcap
# ROMARKETCAP_DB_PASSWORD=CHANGE_ME
#
# FLORISTMARKET_DB=floristmarket
# FLORISTMARKET_DB_USER=floristmarket
# FLORISTMARKET_DB_PASSWORD=CHANGE_ME
#
# FIVMATCH_DB=fivmatch
# FIVMATCH_DB_USER=fivmatch
# FIVMATCH_DB_PASSWORD=CHANGE_ME

# ===========================================
# Vercel environment variables
# ===========================================
# Set these in Vercel project settings → Environment Variables:
#
# NEXT_PUBLIC_API_BASE_URL = https://api.imobintel.ro
# NEXTAUTH_SECRET          = <same as above>
# NEXTAUTH_URL             = https://imobintel.ro
#
# DO NOT set DATABASE_URL on Vercel — Vercel has no direct DB access.
# All API calls are proxied to the VPS via next.config.ts rewrites.
